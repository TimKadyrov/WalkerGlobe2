<Window x:Class="WalkerGlobe2.WpfSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:globe="clr-namespace:WalkerGlobe2.Api;assembly=WalkerGlobe2"
        Title="WalkerGlobe WPF Sample" Width="1400" Height="900"
        Background="#1E1E1E"
        Closed="OnClosed">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Control Panel -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock Text="WalkerGlobe WPF Sample" FontWeight="Bold" FontSize="16" Foreground="White" Margin="0,0,0,12"/>

                <TextBlock Text="Time Controls" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="btnPlay" Content="Play" Width="60" Click="OnPlayClick" Margin="0,0,4,0"/>
                    <Button x:Name="btnStop" Content="Stop" Width="60" Click="OnStopClick" Margin="0,0,4,0"/>
                    <Button x:Name="btnReset" Content="Reset" Width="60" Click="OnResetClick"/>
                </StackPanel>
                <TextBlock x:Name="txtTime" Text="Time: 0s" Foreground="LightGray" Margin="0,0,0,8"/>

                <Separator Margin="0,4"/>

                <TextBlock Text="Scene" FontWeight="Bold" Foreground="White" Margin="0,8,0,4"/>
                <CheckBox x:Name="chkGrid" Content="Show Lat/Lon Grid" Foreground="White" IsChecked="False" Checked="OnGridToggle" Unchecked="OnGridToggle" Margin="0,4"/>
                <CheckBox x:Name="chkSatellites" Content="Show Satellites" Foreground="White" IsChecked="True" Checked="OnSatToggle" Unchecked="OnSatToggle" Margin="0,4"/>
                <CheckBox x:Name="chkGroundStations" Content="Show Ground Stations" Foreground="White" IsChecked="True" Checked="OnEsToggle" Unchecked="OnEsToggle" Margin="0,4"/>
                <CheckBox x:Name="chkLinks" Content="Show Link Lines" Foreground="White" IsChecked="True" Checked="OnLinksToggle" Unchecked="OnLinksToggle" Margin="0,4"/>
                <CheckBox x:Name="chkDayNight" Content="Day/Night Globe" Foreground="White" IsChecked="False" Checked="OnDayNightToggle" Unchecked="OnDayNightToggle" Margin="0,4"/>
                <CheckBox x:Name="chkAtmosphere" Content="Atmosphere" Foreground="White" IsChecked="False" Checked="OnAtmosphereToggle" Unchecked="OnAtmosphereToggle" Margin="0,4"/>
                <CheckBox x:Name="chkCones" Content="Coverage Cones" Foreground="White" IsChecked="False" Checked="OnConesToggle" Unchecked="OnConesToggle" Margin="0,4"/>

                <Separator Margin="0,8"/>

                <TextBlock Text="Satellite Scale" Foreground="White" Margin="0,4,0,2"/>
                <Slider x:Name="sliderSatScale" Minimum="0.5" Maximum="3.0" Value="1.0" ValueChanged="OnSatScaleChanged"/>

                <Separator Margin="0,8"/>

                <TextBlock Text="Legend" FontWeight="Bold" Foreground="White" Margin="0,4,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Ellipse Width="10" Height="10" Fill="LightBlue" Margin="0,0,6,0"/>
                    <TextBlock Text="NGSO Satellites" Foreground="LightGray"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Ellipse Width="10" Height="10" Fill="LightGreen" Margin="0,0,6,0"/>
                    <TextBlock Text="Active Satellite" Foreground="LightGray"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Ellipse Width="10" Height="10" Fill="Yellow" Margin="0,0,6,0"/>
                    <TextBlock Text="Ground Stations" Foreground="LightGray"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Rectangle Width="12" Height="3" Fill="Yellow" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Link Lines (LOS)" Foreground="LightGray"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Rectangle Width="12" Height="3" Fill="Green" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Lat/Lon Grid" Foreground="LightGray"/>
                </StackPanel>

                <Separator Margin="0,12"/>
                <TextBlock Text="Camera: Left-drag orbit, Right-drag zoom, Scroll wheel" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 3D Globe Viewport -->
        <globe:GlobeWpfControl x:Name="globeControl" Grid.Column="1"/>
    </Grid>
</Window>
